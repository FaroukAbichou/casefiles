    {
      "id": "overview",
      "title": "Overview",
      "blocks": [
        {
          "type": "mediumText",
          "content": "Kotteb bridges spiritual wellness and mental health support by combining Quran-first habits with accessible, culturally aware therapy experiences."
        },
        {
          "type": "quote",
          "content": "Trust grows when the interface feels safe, familiar, and respectful."
        },
        {
          "type": "smallText",
          "content": "Designed for daily reading + prayer routines, with support that feels one step away."
        }
      ]
    },
    {
      "id": "tl-dr-summary",
      "title": "TL;DR Summary",
      "blocks": [
        {
          "type": "bulletList",
          "items": [
            "Problem: Muslim users needed one trusted space for Quran routines and emotional support",
            "Approach: culturally respectful UX and simple flows for reading, prayer, and therapist discovery",
            "Impact: stronger trust, clearer user journeys, and better access to qualified care"
          ]
        },
        {
          "type": "tinyText",
          "content": "TL;DR: fewer steps, calmer tone, more consistent user journeys."
        }
      ]
    },
    {
      "id": "role-process",
      "title": "Role & Process",
      "blocks": [
        {
          "type": "text",
          "content": "I led UX/UI direction from discovery to handoff: user interviews, flow architecture, interface design, and collaboration with product and engineering to keep the experience practical and shippable."
        },
        {
          "type": "bulletList",
          "items": [
            "Discovery: mapped Quran routines + therapy expectations through community input",
            "Design: shaped information architecture and calm interaction patterns",
            "Validation: iterated based on usability feedback from representative users"
          ]
        },
        {
          "type": "microText",
          "content": "Constraint: build a cohesive experience without overwhelming users during sensitive moments."
        }
      ]
    },
